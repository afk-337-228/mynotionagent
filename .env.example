# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_USER_ID=your_telegram_user_id

# OpenRouter (free tier: gemini-2.5-flash, meta-llama/llama-3.1-8b-instruct)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Notion
NOTION_API_KEY=ntn_...
NOTION_PARENT_PAGE_ID=uuid_of_page_where_databases_will_be_created

# Whisper: local (faster-whisper) or api (openai — paid)
WHISPER_MODE=local

# Optional
LOG_LEVEL=INFO
# STATE_DB_PATH=/app/data/state.db  # for Docker persistence

# Vercel: secret to call /api/set_webhook?secret=... (set webhook once after deploy)
WEBHOOK_SECRET=your_random_secret_string
